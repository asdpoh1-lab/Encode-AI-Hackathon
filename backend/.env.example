# Copy to `.env` or set in your process manager / hosting dashboard.

# HTTP bind (default: 3001 / 0.0.0.0)
PORT=3001
HOST=0.0.0.0

# SQLite file path (default: backend/data/agentolympics.db)
# DB_PATH=/absolute/path/to/agentolympics.db

# Required for POST /admin/heat/* and GET /admin/heat/summary (send header X-Admin-Token)
HEATS_ADMIN_SECRET=change-me-in-production
